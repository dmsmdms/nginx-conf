# --- Системные настройки ---
user nginx nginx;
master_process off;         # Режим без мастер-процесса (экономия процессов)
worker_processes 1;         # Оптимально для легковесных контейнеров

events {
    worker_connections 1024;
    multi_accept on;        # Принимать сразу все новые соединения из очереди
    use epoll;              # Эффективный метод обработки событий в Linux
}

http {
    # --- Логирование ---
    access_log off;         # Отключено для повышения производительности
    log_not_found off;      # Не спамить в логи ошибками 404 для favicon и т.д.
    error_log /var/log/nginx/error.log warn;

    # --- Оптимизация передачи данных ---
    sendfile on;            # Прямая передача файла из ядра в сокет
    tcp_nopush on;          # Отправка заголовков одним пакетом
    tcp_nodelay on;         # Отключает задержку Nagle для малых пакетов
    server_tokens off;      # Скрытие версии Nginx в заголовках

    # --- Тайм-ауты и буферы ---
    client_body_timeout 10s;
    client_header_timeout 10s;
    keepalive_timeout 30s;
    send_timeout 10s;
    client_max_body_size 10m;

    # --- SSL и безопасность ---
    ssl_session_tickets off;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 1d;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;

    # --- Кэширование дескрипторов открытых файлов ---
    open_file_cache max=1000 inactive=20s;
    open_file_cache_valid 30s;
    open_file_cache_min_uses 2;
    open_file_cache_errors on;

    # --- Ограничения нагрузки (Rate Limiting) ---
    limit_req_zone $binary_remote_addr zone=mylimit:10m rate=10r/s;
    limit_conn_zone $binary_remote_addr zone=addr:10m;

    # --- Настройка кэша для бэкенда ---
    proxy_cache_path /var/cache/nginx/backend_cache levels=1:2 keys_zone=backend_cache:10m max_size=1g inactive=60m use_temp_path=off;

    # --- Сжатие данных (Gzip) ---
    gzip on;
    gzip_static on;         # Отдача заранее сжатых .gz файлов
    gzip_comp_level 5;
    gzip_min_length 1024;
    gzip_proxied any;
    gzip_vary on;
    gzip_types 
        text/plain text/css text/xml 
        application/javascript application/json application/xml application/xml+rss 
        application/wasm image/svg+xml image/x-icon 
        application/vnd.ms-fontobject application/x-font-ttf font/opentype;

    # --- MIME-типы ---
    types_hash_max_size 4096;
    types_hash_bucket_size 128;
    include mime.types.nginx;

    {# --- Переиспользуемые макросы --- #}
    {% macro proxy_common() -%}
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;

    # Буферизация ответа бекенда
    proxy_buffering on;
    proxy_buffer_size 16k;           # Буфер для заголовков ответа
    proxy_buffers 16 32k;            # 16 буферов по 32k дают суммарно 512k на запрос.
    proxy_busy_buffers_size 64k;     # Ограничивает объем данных, который может быть "занят" (отправляется клиенту)
    proxy_max_temp_file_size 8m;     # Максимальный размер буфера временного файла
    proxy_temp_file_write_size 512k; # Буфер записи на диск
    {%- endmacro %}

    {% macro static_common() -%}
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    {%- endmacro %}

    # Нормализация заголовока, чтобы ключи кэша были чистыми
    map $http_accept_encoding $best_compression {
        ~*gzip   "gzip";
        default  "identity";
    }

    # Определяем, хочет ли клиент HTML
    map $http_accept $is_not_browser {
        default         1;
        "~*text/html"   0;
    }

    {# --- Динамическая генерация серверов приложений --- #}
    {% for app in apps %}
    {% if app.enabled %}
    
    # Бэкенд-группа для {{ app.name }}
    upstream {{ app.name }} {
        server unix:/run/backend/{{ app.name }}.sock;
        keepalive 16;       # Поддержка постоянных соединений с бэкендом
    }

    {% if app.lang %}
    # Определение языка на основе заголовка браузера
    map $http_accept_language $detected_lang_{{ app.name }} {
        default "{{ app.lang[0] }}"; # Первый язык из списка — дефолтный
        {% for lang in app.lang %}"~*^{{ lang }}" "{{ lang }}";{% endfor %}
    }

    # Извлекаем первый сегмент пути как язык для ключа кэша
    map $uri $lang_dir_{{ app.name }} {
        default "{{ app.lang[0]}}";
        {% for lang in app.lang %}"~^/{{ lang }}/" "{{ lang }}";{% endfor %}
    }
    {% endif %}

    server {
        listen 443 ssl;
        http2 on;
        server_name {{ app.domain }};

        # Сертификаты Let's Encrypt
        ssl_certificate /etc/letsencrypt/live/{{ app.domain }}/fullchain.pem;
        ssl_certificate_key /etc/letsencrypt/live/{{ app.domain }}/privkey.pem;

        {% if app.app or app.site %}
        root /var/www/{{ app.name }};
        index index.html;
        {% endif %}

        {% if app.lang %}
        # Редирект для мультиязычности
        location = / {
            return 301 https://$host/$detected_lang_{{ app.name }}/;
        }
        {% endif %}

        # Ограничение частоты запросов
        limit_req zone=mylimit burst=20 nodelay;
        limit_conn addr 10;

        {% if app.app %} # Клиентское SPA-приложение по пути /<lang>/app {% if app.lang %}
        location ~ ^/(?<lang_prefix>{% for lang in app.lang %}{{ lang }}{% if not loop.last %}|{% endif %}{% endfor %})/app(?<app_uri>/.*)?$ {
            try_files $uri /$lang_prefix/app/index.html;
        {% else %}
        location /app {
            try_files $uri /app/index.html;
        {% endif %} root /var/www/{{ app.name }};
            etag on;
            add_header Cache-Control "no-cache, must-revalidate";
            {{ static_common() }}
        }
        {% endif %}

        {% if app.api %}
        # Проксирование API запросов
        location /api/ {
            proxy_pass http://{{ app.name }};
            proxy_set_header Connection ""; # Сброс заголовка для keepalive
            {{ proxy_common() }}
        }
        {% endif %}

        {% if app.bot %}
        # Проксирование Telegram бота
        location /bot {
            proxy_pass http://{{ app.name }}/bot;
            proxy_set_header Connection "";
            {{ proxy_common() }}
        }
        {% endif %}

        {% if app.ws %}
        # Обработка WebSocket соединений
        location /ws {
            proxy_pass http://{{ app.name }}/ws;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection "Upgrade";
            proxy_read_timeout 3600s; # Увеличенный тайм-аут для сокетов
            {{ proxy_common() }}
        }
        {% endif %}

        {% if app.site %}
        # Статичный контент и точка входа по умолчанию
        location / {
            # Приоритет: точный файл -> файл.html файл -> папка -> прокси на Backend
            try_files $uri $uri.html @backend;
            etag on;
            add_header Cache-Control "no-cache, must-revalidate";
            {{ static_common() }}
        }

        # Именованный location для передачи запроса backend
        location @backend {
            proxy_pass http://{{ app.name }};
            proxy_set_header Connection "";
            proxy_set_header If-None-Match $http_if_none_match;
            proxy_set_header If-Modified-Since $http_if_modified_since;
            {{ proxy_common() }}

            # Кеширование ответов бекенда
            proxy_cache backend_cache;
            proxy_cache_revalidate on;
            proxy_cache_valid 200 1s;
            proxy_cache_key "$scheme$request_method$host$request_uri{% if app.lang %}$lang_dir_{{ app.name }}{% endif %}$best_compression";
            proxy_cache_use_stale error timeout updating http_500 http_502 http_503 http_504;
            proxy_cache_lock on;
            add_header X-Cache-Status $upstream_cache_status;

            # Перехват ошибок бэкенда для отображения кастомных страниц Nginx
            proxy_intercept_errors on;
            error_page 404 /404.html;
            error_page 500 502 503 504 /50x.html;
        }

        # Защита страниц ошибок (доступ только внутренний)
        location ~ ^/(404|50x)\.html$ {
            internal;

            # Отдаем HTML только если клиент — браузер, иначе просто код ошибки
            if ($is_not_browser) {
                return 404;
            }
        }
        {% endif %}

        {% if app.app or app.site %}
        # Кэширование медиа-ассетов и статики
        location ~* \.(?:css|js|jpg|jpeg|gif|png|svg|wasm|ico|webp|avif|woff2|mp4|mp3|json|webmanifest)$ {
            try_files $uri =404;
            expires max; 
            add_header Cache-Control "public, max-age=315360000, immutable, no-transform";
            {{ static_common() }}
        }

        # Запрет доступа к скрытым файлам (например, .env или .git)
        location ~ /\. {
            deny all;
        }
        {% endif %}
    }
    {% endif %}
    {% endfor %}

    # Редирект HTTP -> HTTPS для всех активных доменов
    server {
        listen 80;
        server_name {% for app in apps %}{% if app.enabled %}{{ app.domain }} {% endif %}{% endfor %};
        return 301 https://$host$request_uri;
    }

    {% if binpkg.enabled %}
    # --- Локальный репозиторий бинарных пакетов ---
    server {
        listen 80;
        server_name {{ binpkg.domain }};
        root {{ binpkg.path }};

        location / {
            allow {{ binpkg.allow_network }}; # Доступ только из разрешенной сети
            deny all;
        }
    }
    {% endif %}
}
